# Sirens Forge environment example
# -----------------------------------------------------------------------------
# Placeholder values are examples only. Do not commit real secrets, real tokens,
# real bucket credentials, or private account IDs.
#
# Configure Vercel, Railway/API, and RunPod with only the variables each runtime
# needs. Keep server-side secrets out of NEXT_PUBLIC_* variables.

# -----------------------------------------------------------------------------
# Public app config (safe to expose to the browser)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://example.com
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me_supabase_anon_key

# -----------------------------------------------------------------------------
# Supabase server-side (server/runtime only)
# -----------------------------------------------------------------------------
# Used by API routes, Stripe customer lookup, generation logging, LoRA cache
# lookup, and the RunPod trainer.
SUPABASE_URL=https://example.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace_me


# -----------------------------------------------------------------------------
# X / Twitter Autopost OAuth (server/runtime only)
# -----------------------------------------------------------------------------
# Text-only MVP. Verify requested scopes in the X Developer portal before production.
# Do not request media.write until the media upload pass.
X_CLIENT_ID=replace_me_x_client_id
X_CLIENT_SECRET=replace_me_x_client_secret
X_REDIRECT_URI=https://example.com/api/autopost/connect/x/callback
X_OAUTH_SCOPES=tweet.read tweet.write users.read offline.access
X_API_BASE_URL=https://api.x.com

# Autopost provider credential encryption and OAuth state signing (server/runtime only).
# AUTOPOST_TOKEN_ENCRYPTION_KEY must be a base64-encoded 32-byte key.
AUTOPOST_TOKEN_ENCRYPTION_KEY=replace_me_base64_32_byte_key
AUTOPOST_TOKEN_KEY_VERSION=1
AUTOPOST_OAUTH_STATE_SECRET=replace_me_random_oauth_state_secret

# Internal server-to-server adapter auth. Never expose this to browsers.
AUTOPOST_INTERNAL_ADAPTER_SECRET=replace_me_random_internal_adapter_secret
# Explicit staging/internal gate for /api/autopost/run dispatch. Keep false unless manually testing server-side dispatch.
AUTOPOST_X_RUN_DISPATCH_ENABLED=false

# -----------------------------------------------------------------------------
# Fanvue Autopost OAuth (server/runtime only; gated OFF by default)
# -----------------------------------------------------------------------------
FANVUE_CONNECT_ENABLED=false
FANVUE_RUN_DISPATCH_ENABLED=false
FANVUE_POST_VERIFY_ENABLED=false
FANVUE_CLIENT_ID=
FANVUE_CLIENT_SECRET=
FANVUE_REDIRECT_URI=https://example.com/api/autopost/connect/fanvue/callback
FANVUE_OAUTH_SCOPES=read:self read:creator read:post write:post read:media write:media
FANVUE_API_BASE_URL=
FANVUE_OAUTH_AUTHORIZE_URL=
FANVUE_OAUTH_TOKEN_URL=
FANVUE_API_VERSION=

# -----------------------------------------------------------------------------
# Stripe (server/runtime only)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=replace_me_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_me_stripe_webhook_secret

# Checkout subscription price IDs are read from env overrides by tier slug.
# Leave blank unless this environment should create Stripe Checkout sessions for
# that tier. Do not put live price IDs here unless this file remains local only.
STRIPE_PRICE_OG_THRONE=replace_me
STRIPE_PRICE_EARLY_BIRD=replace_me
STRIPE_PRICE_PRIME_ACCESS=replace_me

# -----------------------------------------------------------------------------
# Railway/API / generation gateway
# -----------------------------------------------------------------------------
# app/api/generate forwards generation requests to this gateway.
RUNPOD_BASE_URL=https://example-railway-api.example.com

# -----------------------------------------------------------------------------
# R2 / S3-compatible storage
# -----------------------------------------------------------------------------
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me

# Region defaults vary by runtime. App upload routes use AWS_DEFAULT_REGION;
# start-training uses R2_REGION; the trainer reads AWS_DEFAULT_REGION.
AWS_DEFAULT_REGION=auto
R2_REGION=auto

# R2_BUCKET is the default/shared bucket fallback used by app routes and legacy
# paths. Dataset Doctor raw uploads use R2_BUCKET in the master/frontend upload
# URL route.
R2_BUCKET=identity-loras

# Trainer dataset download fallback. Dataset Doctor final dataset bucket/prefix
# come from the API/Railway Dataset Doctor export and are stored into Supabase
# fields; the trainer uses those stored fields first when present.
R2_DATASET_BUCKET=replace_me_dataset_bucket
R2_DATASET_PREFIX_ROOT=lora_datasets

# Trainer artifact upload bucket/prefix. Generation LoRA cache prefers
# user_loras.artifact_r2_bucket, then falls back to R2_BUCKET, then
# "identity-loras".
R2_ARTIFACT_BUCKET=replace_me_artifact_bucket
R2_ARTIFACT_PREFIX_ROOT=loras

# -----------------------------------------------------------------------------
# RunPod LoRA trainer
# -----------------------------------------------------------------------------
PRETRAINED_MODEL=/workspace/models/replace_me_model.safetensors
VAE_PATH=/workspace/models/replace_me_vae.safetensors
LORA_LOCAL_TRAIN_ROOT=/workspace/train_data
LORA_OUTPUT_ROOT=/workspace/output_loras
TRAIN_SCRIPT=/workspace/sd-scripts/sdxl_train_network.py
PYTHON_BIN=/usr/bin/python3
LORA_NETWORK_MODULE=networks.lora
LORA_CONCEPT_TOKEN=concept
LORA_CAPTION_EXTENSION=.txt
LORA_USE_BLIP_CAPTIONS=1
LORA_BLIP_MODEL_ID=Salesforce/blip-image-captioning-base
LORA_TRIGGER_SUFFIX=woman
LORA_CAPTION_STYLE_PREFIX=
LORA_NOTIFY_ENDPOINT=https://example.supabase.co/functions/v1/lora-status-notify
